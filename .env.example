# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://hhp_user:your_password@localhost:5432/hhp_db"

# ─────────────────────────────────────────────
# NEXTAUTH
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://hhp.kevinhamilton.ca"

# For local development
# NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────
# Create at: https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─────────────────────────────────────────────
# SENDGRID EMAIL
# ─────────────────────────────────────────────
SENDGRID_API_KEY="your-sendgrid-api-key"
EMAIL_FROM="noreply@kevinhamilton.ca"
EMAIL_FROM_NAME="Hicks Hockey Pool"

# ─────────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://hhp.kevinhamilton.ca"
NEXT_PUBLIC_APP_NAME="Hicks Hockey Pool"

# Timezone for all scheduled tasks
TZ="America/Toronto"

# ─────────────────────────────────────────────
# NHL API
# ─────────────────────────────────────────────
# No API key needed for the unofficial NHL API
NHL_API_BASE_URL="https://api-web.nhle.com/v1"
NHL_STATS_API_URL="https://api.nhle.com/stats/rest/en"
